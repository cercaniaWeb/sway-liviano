# --- CONFIGURACIÓN DE SWAY (BASADA EN END-4) ---

# Variables de Teclas
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term alacritty

# Colores Catppuccin Mocha
set $base #1e1e2e
set $text #cdd6f4
set $accent #cba6f7
set $overlay #313244
set $urgent #f38ba8

# Estética de Ventanas
font pango:JetBrainsMono Nerd Font 10
floating_modifier $mod
default_border none
default_floating_border none
gaps inner 10
gaps outer 5
smart_gaps on

# Decoración de Ventanas [Border, BG, Text, Indicator, Child_Border]
client.focused          $accent $base $text $accent $accent
client.focused_inactive $overlay $base $text $overlay $overlay
client.unfocused        $overlay $base $text $overlay $overlay
client.urgent           $urgent $base $text $urgent $urgent

# Auto-ejecución (Startup)
exec swaync
exec waybar
exec swaybg -m fill -i ~/Images/Wallpapper/wallpaperflare.com_wallpaperamarillo.jpg
exec wl-paste --type text --watch cliphist store 
exec wl-paste --type image --watch cliphist store

# Atajos de Teclado (Keybindings)
bindsym $mod+Return exec $term
bindsym $mod+q kill
bindsym $mod+d exec rofi -show drun -theme ~/.config/rofi/config.rasi
bindsym $mod+Shift+c reload
bindsym $mod+x exec swaynag -t warning -m '¿Cerrar sesión?' -b 'Sí' 'swaymsg exit'

# Gestión de Ventanas
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

# Cambiar Foco
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

# Mover Ventanas
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

# Modos de Layout
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+Shift+e layout toggle split

# Control de Audio y Brillo
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Control Multimedia (Spotify/Playerctl)
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous
bindsym $mod+p exec playerctl play-pause
bindsym $mod+bracketright exec playerctl next
bindsym $mod+bracketleft exec playerctl previous

### SWAY LIVIANO ADDITIONS ###

# Input config
input * {
    xkb_layout "latam"
    repeat_delay 250
    repeat_rate 50
}

input type:touchpad {
    tap enabled
    natural_scroll enabled
    click_method clickfinger
    dwt enabled
}

# Dashboard Rules (Refined for reliable floating behavior)
# Sidebar Dashboard
for_window [class="sway-dashboard-sidebar"] floating enable, border none, sticky enable, resize set 400 1000, move position 10 40
for_window [app_id="sway-dashboard-sidebar"] floating enable, border none, sticky enable, resize set 400 1000, move position 10 40

# Centered Dashboard / Shortcuts
for_window [class="sway-dashboard-center"] floating enable, border none, sticky enable, resize set 900 700, move position center
for_window [app_id="sway-dashboard-center"] floating enable, border none, sticky enable, resize set 900 700, move position center
for_window [title="Sway Liviano - Agent Skills"] floating enable, border none, sticky enable, resize set 900 700, move position center

# Standard Windows (Force Tiling)
for_window [class="thorium-browser"] floating disable
for_window [app_id="thorium-browser"] floating disable
for_window [class="Thorium-browser"] floating disable
for_window [app_id="Thorium-browser"] floating disable

# Dashboard Toggle
bindsym $mod+i exec /home/lrs/sway-liviano/dashboard/launch.sh
bindsym $mod+g exec /home/lrs/sway-liviano/dashboard/launch.sh manager
bindsym $mod+b exec thorium-browser --enable-features=UseOzonePlatform --ozone-platform=wayland --enable-transparent-visuals
bindsym $mod+e exec alacritty -e yazi
bindsym $mod+Shift+a exec /home/lrs/sway-liviano/dashboard/launch.sh shortcuts.html
bindsym $mod+Shift+g exec /home/lrs/sway-liviano/dashboard/launch.sh manager
bindsym $mod+Shift+i exec /home/lrs/sway-liviano/dashboard/launch.sh tmux_shortcuts.html
bindsym $mod+Shift+y exec /home/lrs/sway-liviano/dashboard/launch.sh system_shortcuts.html
bindsym $mod+Shift+p exec /home/lrs/sway-liviano/dashboard/launch.sh agent_skills.html
bindsym $mod+n exec swaync-client -t -sw

# Screenshots
bindsym Print exec grim - | tee ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png | wl-copy
bindsym $mod+Shift+s exec grim -g "$(slurp)" - | tee ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png | wl-copy

# Locking
bindsym $mod+Escape exec /home/lrs/sway-liviano/scripts/lock.sh

